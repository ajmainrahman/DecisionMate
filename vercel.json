{
  "version": 2,
  "buildCommand": "BASE_PATH=/ pnpm --filter @workspace/decisionmate run build",
  "outputDirectory": "artifacts/decisionmate/dist",
  "installCommand": "npm install -g pnpm@latest && pnpm install --frozen-lockfile --ignore-scripts",
  "framework": null,
  "env": {
    "BASE_PATH": "/"
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/[[...route]]" },
    { "source": "/((?!api).*)", "destination": "/index.html" }
  ]
}
